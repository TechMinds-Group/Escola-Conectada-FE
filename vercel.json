{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:prod",
  "outputDirectory": "dist/escola-conectada",
  "installCommand": "npm install",
  "framework": null,
  "redirects": [
    {
      "source": "/",
      "destination": "/dashboard",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/((?!.*\\.).)*",
      "destination": "/index.html"
    }
  ]
}
